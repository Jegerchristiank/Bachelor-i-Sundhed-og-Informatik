\def\makeprojecttitle{
    \begingroup
    \thispagestyle{empty}
    \normalfont

    \begin{flushright}
    \@ptype\\
    \@kuheaderone\\
    \@kuheadertwo\\
    \@date
    \end{flushright}

    \vspace*{\stretch{0.08}}

    \ifdefined\@fpimage
        \begin{center}
        \includegraphics[width=.48\textwidth,height=72mm,keepaspectratio]{\@fpimage}
        \end{center}
    \fi

    \vspace{0.8cm}

    \begin{center}
        {\fontsize{24.88}{29.86}\selectfont\bfseries \@title\par}
        \vspace{0.45cm}
        {\fontsize{17.28}{20.74}\selectfont \@subtitle\par}
        \vspace{0.7cm}
        {\fontsize{14.4}{17.28}\selectfont af\par}
        \vspace{0.1cm}
        {\fontsize{14.4}{17.28}\selectfont \@author\par}
    \end{center}

    \vspace*{\stretch{1.4}}

    \noindent
    \begin{minipage}[t]{0.56\textwidth}
    \textbf{Vejleder}\\
    \@advisor
    \end{minipage}
    \hfill
    \begin{minipage}[t]{0.40\textwidth}
    \fontsize{10.95}{13.6}\selectfont
    \raggedleft
    \textbf{\@kudegree}\\
    \@kuunit\\
    \@kudepartment
    \end{minipage}

    \clearpage
    \endgroup
}

\def\makekutitle{
	    \thispagestyle{empty}
	    \AddToShipoutPictureBG*{\includegraphics[width=\paperwidth,height=\paperheight]{\@kucoverbackground}}
	    \ 

	    \begin{textblock*}{\@kuheaderbackgroundwidth}(15mm,10mm)
	    \noindent{\color{white}\rule{\@kuheaderbackgroundwidth}{28mm}}
	    \end{textblock*}
	    \begin{textblock*}{170mm}(19mm,17mm)
	    \noindent{\sffamily\color{\@kuheadercolor}\fontsize{13}{13}\selectfont\addfontfeatures{LetterSpace=18}\@kuheaderone\\[5pt]
	    \fontsize{9}{9}\selectfont\addfontfeatures{LetterSpace=14}\@kuheadertwo}
	    \end{textblock*}
	    
	    \ifdefined\@fpimage
        \begin{textblock}{10}(1.5,4.7)
        \noindent\includegraphics*[width=\textwidth, height=80mm, keepaspectratio]{\@fpimage}
        \end{textblock}
    \fi
    
    \begin{textblock}{10}(1.5,10.4) \noindent\sffamily\fontsize{20}{20}\selectfont \textbf{\@ptype}
    \end{textblock}
    
    \ifdefined\@subtitle
        \begin{textblock}{10}(1.5,11.0) \noindent\sffamily\fontsize{14}{14}\selectfont \@author
        \end{textblock}
    \fi

    \ifdefined\@ptype
        \begin{textblock}{10}(1.5,11.9)
        \noindent\sffamily\fontsize{20}{20}\selectfont \textbf{\@title}
        \end{textblock}
    \fi
    
    \begin{textblock}{10}(1.5,12.5)
        \noindent\raggedright\sffamily\fontsize{14}{14}\selectfont \@subtitle
    \end{textblock}
    
    \begin{textblock}{10}(1.5,13.7)
    \noindent\sffamily\fontsize{11}{11}\selectfont Dato: \@date
    \end{textblock}
    
    \ifdefined\@advisor
        \begin{textblock}{10}(1.5,14.2)
        \noindent\sffamily\fontsize{11}{11}\selectfont Vejleder: \@advisor
        \end{textblock}
    \fi
    
    \newpage
    \noindent
}

\renewcommand{\maketitle}{\makekutitle}
